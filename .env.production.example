# TulipAgent 生产环境配置
# 复制此文件为 .env 并填入实际值

# ===== 应用配置 =====
DEBUG=false

# CORS 允许的来源（Docker + Nginx 反向代理下，前后端同源，CORS 不会触发）
# 只在直接暴露后端端口时才需配置
# CORS_ORIGINS=http://your-server-ip,https://your-domain.com

# ===== 前端配置 =====
# Docker + Nginx 部署：留空 → 前端用相对路径 /api/ → 同源 → 无 CORS
# 非 Nginx 部署：设为后端完整地址，如 http://your-server-ip:8000
NEXT_PUBLIC_API_URL=

# ===== LLM 配置 =====
# 选择提供商: openai / deepseek / ollama
LLM_PROVIDER=deepseek

# DeepSeek 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI 配置（如果使用 OpenAI）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Ollama 配置（如果使用本地模型）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# LLM 通用配置
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ===== 数据库配置 =====
DATABASE_URL=sqlite+aiosqlite:///./data/sqlite/tulipagent.db
CHROMA_PERSIST_DIR=./data/chroma
FILES_DIR=./data/files

# ===== 快递100 API（可选）=====
# KUAIDI100_CUSTOMER=your_customer
# KUAIDI100_KEY=your_key
